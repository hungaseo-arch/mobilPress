{
  "name": "mobilpress-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:only": "vite build",
    "typecheck": "vue-tsc -b --noEmit",
    "preview": "vite preview",
    "predeploy": "npm run build && cp dist/index.html dist/404.html",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@neondatabase/neon-js": "^0.6.2-beta",
    "lucide-vue-next": "^0.475.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-sonner": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.5.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.3",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
