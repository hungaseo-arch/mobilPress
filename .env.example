# ── 데이터 소스 모드 ─────────────────────────────
# mock  : 내장 mock API + localStorage (기본값, 가입 불필요)
# neon  : Neon Data API + Neon Auth (docs/NEON-SETUP.md 참고)
# proxy : /api 를 자체 백엔드로 프록시
VITE_DATA_MODE=mock

# ── Neon (VITE_DATA_MODE=neon 일 때 필수) ────────
# Neon 콘솔 → 프로젝트 → Data API 탭에서 발급되는 REST 엔드포인트
VITE_NEON_DATA_API_URL=

# Neon 콘솔 → Auth 탭 → Configuration 의 Auth URL
VITE_NEON_AUTH_URL=

# ── 자체 백엔드 프록시 (VITE_DATA_MODE=proxy) ───
VITE_API_PROXY_TARGET=
